# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/threadline?retryWrites=true&w=majority

# CORS — Angular dev server origin
CLIENT_URL=http://localhost:4200

# Admin API key (send as header: x-admin-key)
ADMIN_API_KEY=change-me-to-a-secure-random-string

# JWT Secret for authentication
JWT_SECRET=change-me-to-a-secure-random-jwt-secret

# PayHere Sandbox
PAYHERE_MERCHANT_ID=121XXXX
PAYHERE_MERCHANT_SECRET=your_sandbox_merchant_secret
PAYHERE_CURRENCY=LKR
PAYHERE_RETURN_URL=http://localhost:4200/checkout/success
PAYHERE_CANCEL_URL=http://localhost:4200/checkout/cancel
PAYHERE_NOTIFY_URL=http://localhost:5000/api/payments/notify
